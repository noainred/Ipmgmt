# Copy to deploy/.env and set strong values. Used by docker-compose.
# Collector authenticates to the ingest/config API with this key:
INGEST_API_KEY=change-me-strong-ingest-key
# Gates write access to the web Settings page (/settings):
ADMIN_TOKEN=change-me-strong-admin-token
# PostgreSQL password (db service + portal DATABASE_URL):
POSTGRES_PASSWORD=change-me-strong-db-password
